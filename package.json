{
	"name": "zotero-alt-reader",
	"description": "An alternative reader for Zotero",
	"author": "Mark Huang @huangyxi",
	"homepage": "https://github.com/huangyxi/zotero-alt-reader",
	"config": {
		"pluginName": "Alternative Reader",
		"pluginId": "zotero-alt-reader@hyxi.dev",
		"pluginInstance": "AltReader",
		"zoteroVersion": {
			"strict_min_version": "9.0",
			"strict_max_version": "9.*"
		}
	},
	"scripts": {
		"build": "wxt build -b firefox",
		"package": "wxt zip -b firefox",
		"check": "npm-run-all lint typecheck",
		"lint": "npm-run-all --continue-on-error lint:*",
		"lint:eslint": "eslint",
		"lint:prettier": "prettier --check .",
		"format": "npm-run-all format:*",
		"format:eslint": "eslint --fix",
		"format:prettier": "prettier --write .",
		"typecheck": "tsc --noEmit",
		"postinstall": "wxt prepare"
	},
	"devDependencies": {
		"@typescript-eslint/eslint-plugin": "^8.61.0",
		"@typescript-eslint/parser": "^8.61.0",
		"eslint": "^10.5.0",
		"eslint-plugin-simple-import-sort": "^13.0.0",
		"npm-run-all2": "^9.0.2",
		"prettier": "^3.8.4",
		"prettier-plugin-multiline-arrays": "^4.1.9",
		"typescript": "^6.0.3",
		"vite": "^8.0.16",
		"wxt": "^0.20.26",
		"zotero-types": "^4.1.2"
	}
}
